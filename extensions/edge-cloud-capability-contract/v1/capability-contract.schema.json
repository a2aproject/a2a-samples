{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/a2aproject/a2a-samples/extensions/edge-cloud-capability-contract/v1/capability-contract.schema.json",
  "title": "Edge-Cloud Capability Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "executionSites",
    "sideEffects",
    "attestationMethods",
    "verificationMethods"
  ],
  "properties": {
    "version": {
      "const": "1.0"
    },
    "executionSites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "region",
          "p95LatencyMs",
          "offlineCapable",
          "acceptedDataClassifications"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "enum": [
              "edge",
              "cloud"
            ]
          },
          "region": {
            "type": "string",
            "minLength": 1
          },
          "p95LatencyMs": {
            "type": "integer",
            "minimum": 1
          },
          "offlineCapable": {
            "type": "boolean"
          },
          "acceptedDataClassifications": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "sideEffects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "supportsIdempotencyKey"
      ],
      "properties": {
        "kind": {
          "enum": [
            "none",
            "local_write",
            "external_write",
            "physical_action"
          ]
        },
        "supportsIdempotencyKey": {
          "type": "boolean"
        }
      }
    },
    "attestationMethods": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verificationMethods": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
