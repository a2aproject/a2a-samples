OPENAI_API_KEY=your_api_key_here

# Optional: chat model used by the merchant (defaults to gpt-4o-mini).
# OPENAI_MODEL=gpt-4o-mini

# Optional: ports and URLs (defaults shown). Override to avoid clashes or to relocate a process.
# MERCHANT_AGENT_PORT=10003
# MERCHANT_VERIFIER_PORT=3001
# ASSISTANT_AGENT_PORT=10004
# MERCHANT_AGENT_URL=http://localhost:10003
# ASSISTANT_AGENT_URL=http://localhost:10004

# Optional: how long the merchant waits for a voucher presentation before quoting without a
# discount, in milliseconds (default 120000).
# MERCHANT_AUTH_TIMEOUT_MS=120000
