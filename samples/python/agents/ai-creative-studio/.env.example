# ============================================
# GCP Configuration
# ============================================
# Also supports: PROJECT_ID and LOCATION (both naming conventions work)
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# Alternative naming (automatically recognized):
# PROJECT_ID=your-project-id
# LOCATION=us-central1

# ============================================
# Gemini API Configuration
# ============================================
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-api-key

# ============================================
# Agent URLs (Auto-populated by deployment script)
# ============================================
# These will be automatically set after running deploy_complete_system.sh
# or deploy_all_specialists.py
STRATEGIST_AGENT_URL=
COPYWRITER_AGENT_URL=
DESIGNER_AGENT_URL=
CRITIC_AGENT_URL=
PM_AGENT_URL=

# ============================================
# Agent Engine Configuration (Auto-populated)
# ============================================
# These will be set after deploying the Creative Director orchestrator
# to Vertex AI Agent Engine
AGENT_ENGINE_RESOURCE_NAME=
AGENT_ENGINE_ID=

# ============================================
# Local Development Configuration
# ============================================
# For testing agents locally before deployment
HOST=0.0.0.0
PORT=8080
PUBLIC_HOST=localhost
PUBLIC_PORT=8080
PROTOCOL=http

# ============================================
# Optional: Notion Integration (Project Manager)
# ============================================
# Enable Notion integration for the Project Manager agent to:
# - Create project timelines in Notion
# - Generate tasks with deadlines
# - Track deliverables
# - Automatically discover and adapt to your database schema
#
# DYNAMIC SCHEMA DISCOVERY:
# The Project Manager uses MCP to automatically discover your database structure.
# You can name your properties anything you want - the agent will adapt!
#
# Setup Instructions:
# 1. Create a Notion integration at: https://www.notion.so/my-integrations
# 2. Create TWO Notion databases with these TYPES (names can be anything):
#
#    Projects Database:
#    - One Title property (e.g., "Project name", "Nom", "Title", etc.)
#    - One Status property (e.g., "Status", "État", etc.)
#    - One Select property for priority (optional)
#    - One Date property with start & end (e.g., "Dates", "Timeline", etc.)
#    - One Rich text property for summary (optional)
#
#    Tasks Database:
#    - One Title property (e.g., "Task name", "Tâche", etc.)
#    - One Status property
#    - One Select property for priority (optional)
#    - One Date property (e.g., "Due", "Deadline", etc.)
#    - One Relation property linked to Projects database
#
# 3. Share BOTH databases with your integration
# 4. Copy the integration token and Projects database ID below
# 5. Update Tasks database ID in agents/project_manager/agent.py:59
#
# IMPORTANT: When set, these credentials are automatically included
# in the project-manager Cloud Run deployment via deploy.sh,
# deploy_complete_system.sh, and deploy_all_specialists.py
#
# NOTION_API_KEY=ntn_your-notion-integration-token
# NOTION_DATABASE_ID=your-projects-database-id
