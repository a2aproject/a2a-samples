# GCP Deployment Configuration
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GCP_SERVICE_ACCOUNT_NAME=copywriter-sa
GCP_SERVICE_NAME=copywriter

# Runtime Configuration (used by the agent)
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# A2A Server Configuration (for local testing)
HOST=0.0.0.0
PORT=8080
PROTOCOL=http
PUBLIC_HOST=localhost
PUBLIC_PORT=8080

# Cloud Run Configuration (set automatically by deployment)
# PUBLIC_HOST=copywriter-PROJECT_NUMBER.us-central1.run.app
# PUBLIC_PORT=443
# PROTOCOL=https
